    <script>
        function openTab(evt, tabName) {
            const tabContents = document.getElementsByClassName("tab-content");
            for (let i = 0; i < tabContents.length; i++) {
                tabContents[i].classList.remove("active");
            }
            
            const tabButtons = document.getElementsByClassName("tab-button");
            for (let i = 0; i < tabButtons.length; i++) {
                tabButtons[i].classList.remove("active");
            }
            
            document.getElementById(tabName).classList.add("active");
            evt.currentTarget.classList.add("active");
        }
        
        function loadURL(url) {
            const proxiesTab = document.getElementById('proxies');
            const moreTab = document.getElementById('moregames');
            const extraTab = document.getElementById('extra');
            
            if (proxiesTab.classList.contains('active')) {
                const iframe = document.getElementById('proxy-iframe');
                if (iframe) iframe.src = url;
            } else if (moreTab.classList.contains('active')) {
                const iframe = document.getElementById('moregames-iframe');
                if (iframe) iframe.src = url;
            } else if (extraTab.classList.contains('active')) {
                const iframe = document.getElementById('extra-iframe');
                if (iframe) iframe.src = url;
            } else {
                alert("Switch to PROXIES, MORE GAMES or EXTRA SITES tab first!");
            }
        }
        
        // Keyboard shortcuts 1-9
        document.addEventListener('keydown', function(e) {
            const keys = ['gnmath','coolmath','ubghub','pizza','proxies','moregames','github','youtube','extra'];
            if (e.key >= "1" && e.key <= "9") {
                const index = parseInt(e.key) - 1;
                const buttons = document.querySelectorAll('.tab-button');
                if (buttons[index]) {
                    openTab({currentTarget: buttons[index]}, keys[index]);
                }
            }
        });
        
        console.log('%c🍕 Mega Pizza Hub 2026 + GitHub + YouTube + 25 extra sites loaded!', 'color:#ff00aa; font-family:monospace; font-size:14px;');
    </script>
